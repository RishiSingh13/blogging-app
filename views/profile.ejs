<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
     
 <div class="w-full min-h-screen bg-zinc-900 text-white px-8 py-6">

    
    <div class="flex justify-end">
        <a
            href="/logout"
            class="px-4 py-2 bg-red-500 rounded-md hover:bg-red-600 transition"
        >
            Logout
        </a>
    </div>


    <div class="w-full">
        <h3 class="text-3xl font-semibold tracking-wider mt-4">
            Hello 👋, <%= user.name %>
        </h3>

        <h5 class="mt-6 text-lg text-zinc-400">
            You can create a new post
        </h5>

        
        <form action="/post" method="post" class="mt-5 flex flex-col gap-4">
            <textarea
                placeholder="What's on your mind?"
                class="w-full h-40 p-4 bg-zinc-800/30 border border-zinc-700 rounded-lg resize-none outline-none focus:border-blue-500" name="content"
            ></textarea>
             
            

            <input
                type="submit"
                value="Post"
                class="w-fit px-6 py-2 bg-blue-600 rounded-lg cursor-pointer hover:bg-blue-700 transition"
            >
        </form>

        
        <hr class="my-8 border-zinc-700">

    
        <div>
            <h3 class="text-xl font-medium text-zinc-300">
                Your Posts
            </h3>

            <div class="postcontainer mt-5 flex flex-wrap gap-4">

                <% post.reverse().forEach(function(post){%>

                    <div class="p-5 rounded-xl w-[32%] border border-zinc-800 bg-zinc-800/30">
                    <h4 class="text-blue-400 font-medium mb-3">
                       
                    </h4>

                    <p class="text-zinc-300 leading-relaxed">
                       <%=post.content%>
                        
                </p>
                       <div class=" btn flex gap-4">
                    <a class="text-blue-500" href="/like/<%= post._id%>">Like- <span><%= post.likes.length %></span></a>
                    <a class="text-zinc-600" href="/edit/<%=post._id%>">Edit</a>
                </div>         
                    </div>



               <% }) %>
                         


                
            
              
               

            </div>


        </div>
    </div>
</div> 


</body>
</html>