<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
<div class="w-full min-h-screen bg-zinc-900 flex items-center justify-center">
    <form action="/register" method="post" class="bg-zinc-800 border border-zinc-700 p-8 rounded-xl shadow-lg w-full max-w-md flex flex-col gap-4">
        
        <input 
            type="text" 
            placeholder="Name" 
            name="name"
            class="w-full px-4 py-3 bg-zinc-900 text-zinc-100 border border-zinc-700 rounded-lg outline-none focus:border-zinc-500 focus:ring-1 focus:ring-zinc-500"
        >

        <input 
            type="text" 
            placeholder="Username" 
            name="username"
            class="w-full px-4 py-3 bg-zinc-900 text-zinc-100 border border-zinc-700 rounded-lg outline-none focus:border-zinc-500 focus:ring-1 focus:ring-zinc-500"
        >

        <input 
            type="password" 
            placeholder="Password" 
            name="password"
            class="w-full px-4 py-3 bg-zinc-900 text-zinc-100 border border-zinc-700 rounded-lg outline-none focus:border-zinc-500 focus:ring-1 focus:ring-zinc-500"
        >

        <input 
            type="email" 
            placeholder="Email" 
            name="email"
            class="w-full px-4 py-3 bg-zinc-900 text-zinc-100 border border-zinc-700 rounded-lg outline-none focus:border-zinc-500 focus:ring-1 focus:ring-zinc-500"
        >

        <input 
            type="submit" 
            value="Create Account"
            class="w-full py-3 bg-zinc-700 text-white font-medium rounded-lg cursor-pointer hover:bg-zinc-600 transition"
        >
       
    </form>
</div>
</body>
</html>